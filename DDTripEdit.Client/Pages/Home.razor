@page "/"

<PageTitle>Home - DDTripEdit</PageTitle>

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4">
            <span class="text-primary">✈️</span> DDTripEdit
        </h1>
        <p class="lead text-muted">Your personal trip diary — browse, add, and edit your travel memories.</p>
        <a href="/trips" class="btn btn-primary btn-lg mt-2">
            <i class="bi bi-map-fill me-2"></i>View All Trips
        </a>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm text-center p-3">
                <div class="card-body">
                    <div class="fs-1 mb-3">📋</div>
                    <h5 class="card-title">Browse Trips</h5>
                    <p class="card-text text-muted">View all your trips in a sortable, filterable table with pagination.</p>
                    <a href="/trips" class="btn btn-outline-primary">Go to Trips</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm text-center p-3">
                <div class="card-body">
                    <div class="fs-1 mb-3">✏️</div>
                    <h5 class="card-title">Add a Trip</h5>
                    <p class="card-text text-muted">Record a new adventure with date, location, type and score.</p>
                    <a href="/trips/add" class="btn btn-outline-success">Add Trip</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm text-center p-3">
                <div class="card-body">
                    <div class="fs-1 mb-3">💾</div>
                    <h5 class="card-title">CSV Storage</h5>
                    <p class="card-text text-muted">All data persisted in a simple CSV file — easy to share and backup.</p>
                </div>
            </div>
        </div>
    </div>
</div>
